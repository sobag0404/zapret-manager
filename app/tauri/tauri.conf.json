{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zapret Manager",
  "version": "1.2.0",
  "identifier": "local.zapret.manager",
  "build": {
    "beforeDevCommand": "corepack pnpm --dir frontend dev --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "corepack pnpm --dir frontend build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zapret Manager",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": false,
    "icon": ["icons/icon.ico"],
    "resources": {
      "../../profiles": "profiles",
      "../../strategies": "strategies",
      "../../engine": "engine"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFMTJCNDczREUwMTEzOEYKUldTUEV3SGVjN1FTWHFScTYzZTE3aGs5eU1BcGpzVDNyZG13cVNjS0lRTmFUREtoM2lpQXdMOFEK",
      "endpoints": [
        "https://github.com/sobag0404/zapret-manager/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
