{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zapret Manager",
  "version": "0.1.0",
  "identifier": "local.zapret.manager",
  "build": {
    "beforeDevCommand": "corepack pnpm --dir frontend dev --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "corepack pnpm --dir frontend build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Zapret Manager",
        "width": 1180,
        "height": 760,
        "minWidth": 980,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": {
      "../../profiles": "profiles",
      "../../strategies": "strategies",
      "../../engine": "engine"
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": true
      }
    }
  }
}
