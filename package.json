{
  "name": "zapret-manager",
  "private": true,
  "version": "1.2.0",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "dev": "corepack pnpm --dir app/frontend dev",
    "build": "corepack pnpm --dir app/frontend build",
    "test": "vitest run",
    "tauri:dev": "cd app/tauri && cargo tauri dev",
    "tauri:build": "cd app/tauri && cargo tauri build",
    "rust:test": "cargo test --workspace",
    "verify": "corepack pnpm test && corepack pnpm build && cargo test --workspace"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.2",
    "ajv": "^8.17.1",
    "vitest": "^3.2.4"
  }
}
